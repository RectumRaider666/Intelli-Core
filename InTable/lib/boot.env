## boot.env : Environment Persistance and Guided Fixes
VERSION="0.3.7"
DESC="Persist Environment Permissions and Default Apps to Allow Full User Control"
REPO="https://github.com/RectumRaider666/ITable"
DEV="RectumRaider666"

## Logging
LOG="$HOME/.termux/logs/boot.log"

## Port Allocation
export P_GUIDE=54321
export P_WORKER=12345
export P_MAIN=12345

## Remove OEM Paks
REM_PAKS=(
    'com.theorytank.a1up_keyboard'
    'com.theorytank.a1up_launcher'
    'com.theorytank.a1up_screensaver'
    'com.cghs.stresstest'
    'com.zediel.pcbtest'
    'com.DeviceTest'
    'com.android.traceur'
    'com.android.printspooler'
    'com.android.printservice.recommendation'
)

## Install Paks
REQ_PAKS=(
    # Termux Brains
    'https://github.com/termux/termux-app/releases/download/v0.118.3/termux-app_v0.118.3+github-debug_armeabi-v7a.apk' # Termux-App
    'https://github.com/termux/termux-api/releases/download/v0.53.0/termux-api-app_v0.53.0+github.debug.apk' # Termux-API
    'https://f-droid.org/repo/com.termux.boot_7.apk' # Termux-Boot
    'https://f-droid.org/repo/com.termux.float_10.apk' # Termux-Float

    # App Stores
    'https://auroraoss.com/downloads/AuroraStore/Release/AuroraStore-4.7.5.apk' # Aurora Store
    'https://f-droid.org/F-Droid.apk' # F-droid

    # Launchers
    'https://f-droid.org/repo/com.atomicadd.tinylauncher_16.apk' # TinyLauncher

    # File Management
    'https://www.apkmirror.com/apk/nextapp-inc/fx-file-explorer/fx-file-explorer-9-2-0-0-release/fx-file-explorer-9-2-0-0-android-apk-download/' # FX file manager''
)

Suggested_paks=(
    'https://f-droid.org/repo/com.foxdebug.acode_169.apk' # A-Code editor
    'https://www.apkmirror.com/apk/google-inc/drive/drive-2-24-041-0-release/google-drive-2-24-041-0-android-apk-download/' # Google Drive
    'https://www.apkmirror.com/apk/microsoft-onedrive/' # One Drive
    'https://download.mozilla.org/?product=fennec-latest&os=android&lang=en-US' # Firefox
)
