# Bash completion for Autux CLI

_autux() {
    local cur prev opts
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    opts="--tap --swipe --txt --notify --scr --rec --norec --app --noapp --record-taps --label --listcom"
    COMPREPLY=($(compgen -W "${opts}" -- ${cur}))
    return 0
}

complete -F _autux autux
complete -F _autux Autux
