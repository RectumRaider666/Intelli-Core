        {"HeroOfAethric": "com.avalon.rpg"},
        {"ShieldHeroRise": "com.ltgame.dzyzcml.global"},
        {"Twitch": "tv.twitch.android.app"},
        {"Webull": "com.webull.stock"},
        {"TradingView": "com.tradingview.tradingviewapp"},
        {"Chime": "com.onedebit.chime"},
        {"Moomoo": "com.moomoo.trade"},
        {"QuantData": "com.quantdata.app"},
        {"Facebook": "com.facebook.katana"},
        {"Snapchat": "com.snapchat.android"},
