// User Settings for Autux
// Edits to this file will have a direct effect on AUtux on next Boot

{
// Autux Settings
    // All the Base IP Addresses Autux will use to try to connect to ADB
    "IP": [
        ""
    ],

// Session Settings (Boot)
    // Auto-Attempt ABD Connection on BootUnDetected
    "session.attempt": true,

// Alias Settings
    // ls command always show hidden files
    "alias.ls.ShowAll": true,
    // Enable com Associations for Applications
        // Type 'autux --app <app>' to launch an app using its com association ie. autux --app Orna
    "alias.coms.enabled": true,
    // com Associations for Applications
    "alias.coms" : [
        {"Orna": "playorna.com.orna"},
        {"Albion": "com.albiononline"},
        {"Ark": "com.studiowildcard.ark"},
        {"Minecraft": "com.mojang.minecraftpe"},
